# EditorConfig — cross-editor consistency
# https://editorconfig.org

root = true

# Default for everything: UTF-8, LF line endings, trim trailing whitespace, final newline
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# Markdown — preserve trailing whitespace (used for line breaks in Markdown spec)
[*.md]
trim_trailing_whitespace = false
indent_size = 2

# JSON files
[*.json]
indent_size = 2

# YAML files
[*.{yml,yaml}]
indent_size = 2

# Shell scripts — POSIX 4-space convention
[*.sh]
indent_size = 4

# Python (if any) — PEP 8
[*.py]
indent_size = 4

# Makefiles require tabs
[Makefile]
indent_style = tab

# Obsidian Canvas / Bases — leave alone
[*.{canvas,base}]
trim_trailing_whitespace = false
insert_final_newline = false
